{
	"manifest_version": 3,
	"name": "Wikiscript",
	"version": "2026.4.23",
	"description": "Marks visited Wikipedia topics in multiple languages.",
	"permissions": ["history", "storage"],
	"action":
	{
		"default_popup": "index.html"
	},
	"background":
	{
		"service_worker": "background.js"
	},
	"content_scripts": [
	{
		"js": ["content.js"],
		"matches": ["*://*.wikipedia.org/*"],
		"run_at": "document_start"
	}],
	"options_page": "options.html",
	"icons":
	{
		"16": "icons/16.png",
		"32": "icons/32.png",
		"48": "icons/48.png",
		"128": "icons/128.png"
	}
}